{
  "name": "stampstack-adblock",
  "version": "1.3.6",
  "private": true,
  "description": "StampStack — a Manifest V3 ad blocker for Chromium browsers aiming for uBlock Origin blocking parity within the MV3 rules.",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "compile-filters": "node scripts/compile-filters.mjs",
    "update-lists": "node scripts/update-lists.mjs",
    "bundle": "node scripts/build.mjs",
    "build": "npm run compile-filters && npm run bundle",
    "build:store": "npm run compile-filters && node scripts/build.mjs --store",
    "package": "node scripts/package.mjs",
    "ad-audit": "node scripts/ad-audit.mjs",
    "store-assets": "node scripts/make-store-assets.mjs",
    "cws-upload": "node scripts/cws-upload-assist.mjs",
    "icons": "node scripts/make-icons.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "dev": "npm run build && npm run watch"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@adguard/re2-wasm": "^1.2.0",
    "@types/chrome": "^0.0.268",
    "esbuild": "^0.23.0",
    "playwright": "^1.49.1",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "extpay": "^3.1.2"
  }
}
